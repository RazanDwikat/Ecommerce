PORT=5000
MONGO_URI=mongodb://localhost:27017/ecommerce
JWT_SECRET=change_me

# Payment / Stripe
# STRIPE_MODE: "simulator" (local mock, no Stripe account needed) or "real"
STRIPE_MODE=simulator
# Used only when STRIPE_MODE=real
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret (whsec_...). For the simulator any value works as long
# as it matches what the app uses to verify; for real Stripe use the value from
# `stripe listen` or the Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYMENT_CURRENCY=usd
